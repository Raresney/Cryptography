{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["app/**"],
    "buildCommand": "cd app && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd app && npx serve dist -s -l $PORT",
    "restartPolicyType": "ON_FAILURE"
  }
}
